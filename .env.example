# MySQL 데이터베이스 설정
MYSQL_ROOT_PASSWORD=your_root_password     # MySQL 루트 비밀번호 (운영 환경에 맞게 설정)
MYSQL_DATABASE=your_database               # 사용할 데이터베이스 이름
MYSQL_USER=your_user                       # 애플리케이션 DB 접속용 사용자명
MYSQL_PASSWORD=your_password               # 애플리케이션 DB 접속용 비밀번호
MYSQL_PORT=your_port                       # MySQL 포트

# Redis 설정
REDIS_PORT=6379                            # Redis 기본 포트
REDIS_PASSWORD=your_secure_password        # Redis 비밀번호 (필요시 설정, 기본값 없음)

# 프론트엔드 URL (CORS 허용 등)
FRONTEND_URL=http://localhost:3000         # 개발 환경 프론트엔드 주소

# JWT 시크릿 키 (Access Token, Refresh Token 서명용)
ACCESS_TOKEN_SECRET=your_access_token_secret
REFRESH_TOKEN_SECRET=your_refresh_token_secret
